pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'PROJECT_NAME', defaultValue: 'app', description: 'docker compose project name (passed to CD/Final)')
    string(name: 'TARGET_SERVICES', defaultValue: '', description: '(optional) Manual override. e.g. "fe_dev" (empty = always fe_dev)')
    string(name: 'FE_BRANCH', defaultValue: 'develop-fe', description: 'FE branch to sync on EC2')
  }

  environment {
    // EC2에 고정으로 둘 FE repo 경로
    FE_REPO_DIR = "/home/ubuntu/frontend/front-repo"
    // monorepo라면, FE 실제 루트가 있는지 체크(선택)
    FE_APP_DIR  = "/home/ubuntu/frontend/front-repo/frontend/mento"

    // Git repo
    GIT_URL = "https://lab.ssafy.com/s14-webmobile1-sub1/S14P11A704.git"
  }

  stages {

    stage('Context') {
      steps {
        sh '''
          set -euo pipefail
          date "+%Y-%m-%d %H:%M:%S %Z"
          echo "JOB_NAME=$JOB_NAME"
          echo "BUILD_NUMBER=$BUILD_NUMBER"
          echo "BUILD_URL=$BUILD_URL"
          echo "BRANCH_NAME=${BRANCH_NAME:-}"
          echo "PROJECT_NAME=${PROJECT_NAME}"
          echo "PARAM_TARGET_SERVICES=${TARGET_SERVICES}"
          echo "FE_BRANCH=${FE_BRANCH}"
          whoami
          pwd
          git --version || true
        '''
      }
    }

    stage('Sync FE repo on EC2 (clone or fetch/reset)') {
      steps {
        sh '''
          set -euo pipefail

          sudo mkdir -p "$(dirname "${FE_REPO_DIR}")"
          # Jenkins 유저가 쓰기 어렵다면 sudo로 정리(필요 없으면 제거 가능)
          sudo chown -R "$(whoami)":"$(whoami)" "$(dirname "${FE_REPO_DIR}")" || true

          if [ ! -d "${FE_REPO_DIR}/.git" ]; then
            echo "[FE] first time: clone -> ${FE_REPO_DIR}"
            rm -rf "${FE_REPO_DIR}" || true
            git clone -b "${FE_BRANCH}" --single-branch "${GIT_URL}" "${FE_REPO_DIR}"
          else
            echo "[FE] update: fetch + reset --hard (force sync)"
            cd "${FE_REPO_DIR}"
            git fetch origin "${FE_BRANCH}"
            git reset --hard "origin/${FE_BRANCH}"
            git clean -fd
          fi

          echo "[FE] synced commit:"
          cd "${FE_REPO_DIR}"
          git rev-parse --abbrev-ref HEAD || true
          git rev-parse HEAD || true
          git log -1 --pretty=format:"%h | %an | %ad | %s" --date=iso || true

          # (선택) FE 실제 앱 루트 존재만 가볍게 확인 - 실패해도 배포는 진행하도록 하고 싶으면 || true로 바꾸세요.
          if [ ! -f "${FE_APP_DIR}/package.json" ]; then
            echo "WARN: package.json not found at ${FE_APP_DIR} (repo structure check needed)"
          fi
        '''
      }
    }

    stage('Trigger CD/Final') {
      steps {
        script {
          echo "===== TRIGGER CD/FINAL ====="
          echo "PROJECT_NAME=${params.PROJECT_NAME}"
          echo "TARGET_SERVICES='fe_dev'"

          build job: 'CD/Final',
            wait: true,
            parameters: [
              string(name: 'PROJECT_NAME', value: params.PROJECT_NAME),
              string(name: 'TARGET_SERVICES', value: 'fe_dev'),
            ]
        }
      }
    }


    stage('Done') {
      steps {
        sh '''
          set -euo pipefail
          echo "===== FE DEV CI DONE ====="
          echo "FE_REPO_DIR=${FE_REPO_DIR}"
          echo "FE_BRANCH=${FE_BRANCH:-"-"}"
        '''
      }
    }
  }

  post {
    success { echo "CI/FE_Dev SUCCESS" }
    failure { echo "CI/FE_Dev FAILURE" }
    always  { echo "CI/FE_Dev DONE" }
  }
}
