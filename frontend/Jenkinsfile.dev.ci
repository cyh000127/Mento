pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'PROJECT_NAME', defaultValue: 'app', description: 'docker compose project name')
    // [수정] 설명 구체화: 비워두면 fe_dev가 기본값
    string(name: 'TARGET_SERVICES', defaultValue: '', description: '(optional) Manual override. (empty = fe_dev)')
    string(name: 'FE_BRANCH', defaultValue: 'develop-fe', description: 'FE branch to sync on EC2')
  }

  environment {
    FE_REPO_DIR = "/home/ubuntu/frontend/front-repo"
    FE_APP_DIR  = "/home/ubuntu/frontend/front-repo/frontend/mento"
    GIT_URL     = "https://lab.ssafy.com/s14-webmobile1-sub1/S14P11A704.git"
  }

  stages {

    stage('Context') {
      steps {
        sh '''
          set -euo pipefail
          date "+%Y-%m-%d %H:%M:%S %Z"
          echo "JOB_NAME=$JOB_NAME"
          echo "FE_BRANCH=${FE_BRANCH}"
          # [해결] set -u 에러 방지
          echo "PARAM_TARGET_SERVICES=${TARGET_SERVICES:-}"
          whoami
        '''
      }
    }

    stage('Sync FE repo on EC2') {
          steps {
            // [수정] 인증 정보 주입 (Gitlab_PAT ID 확인 필요!)
            withCredentials([usernamePassword(
              credentialsId: 'Gitlab_PAT',  // <-- 여기에 본인의 GitLab 인증 Credential ID 입력
              usernameVariable: 'GIT_USER',
              passwordVariable: 'GIT_PASS'
            )]) {
              sh '''
                set -euo pipefail

                # 1. 인증 정보가 포함된 URL 생성
                # GIT_URL에서 "https://" 제거 후 ID:PW@ 결합
                RAW_URL="${GIT_URL#https://}"
                AUTH_URL="https://${GIT_USER}:${GIT_PASS}@${RAW_URL}"

                # 2. 디렉토리 생성
                if [ ! -d "$(dirname "${FE_REPO_DIR}")" ]; then
                  echo "Creating parent directory..."
                  mkdir -p "$(dirname "${FE_REPO_DIR}")"
                fi

                # 3. Git 작업 (AUTH_URL 사용)
                if [ ! -d "${FE_REPO_DIR}/.git" ]; then
                  echo "[FE] First time: Cloning branch ${FE_BRANCH}..."
                  rm -rf "${FE_REPO_DIR}" || true

                  # 인증된 URL로 Clone
                  git clone -b "${FE_BRANCH}" --single-branch "${AUTH_URL}" "${FE_REPO_DIR}"
                else
                  echo "[FE] Update: Switching to ${FE_BRANCH} and syncing..."
                  cd "${FE_REPO_DIR}"

                  # Remote URL을 인증된 URL로 잠시 업데이트 (또는 직접 fetch)
                  git fetch "${AUTH_URL}" "${FE_BRANCH}"

                  # FETCH_HEAD로 강제 리셋 (가장 깔끔함)
                  git checkout -B "${FE_BRANCH}" FETCH_HEAD
                  git clean -fd
                fi

                # 4. 소유권 변경 (Jenkins(Root) -> Ubuntu)
                echo "Fixing ownership to ubuntu:ubuntu..."
                chown -R ubuntu:ubuntu "$(dirname "${FE_REPO_DIR}")"

                echo "[FE] Current Commit Info:"
                cd "${FE_REPO_DIR}"
                git log -1 --pretty=format:"%h | %an | %ad | %s" --date=iso
              '''
            }
          }
        }

    stage('Trigger CD/Final') {
      steps {
        script {
          // [해결 2] 파라미터가 비어있으면 'fe_dev', 값이 있으면 그 값 사용
          def target = (params.TARGET_SERVICES ?: '').trim()
          if (target == '') {
            target = 'fe_dev'
          }

          echo "===== TRIGGER CD/FINAL ====="
          echo "PROJECT_NAME=${params.PROJECT_NAME}"
          echo "TARGET_SERVICES=${target}"

          build job: 'CD/Final',
            wait: true,
            parameters: [
              string(name: 'PROJECT_NAME', value: params.PROJECT_NAME),
              string(name: 'TARGET_SERVICES', value: target),
            ]
        }
      }
    }

    stage('Done') {
      steps {
        echo "===== FE DEV CI DONE ====="
      }
    }
  }
}