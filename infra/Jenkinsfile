// CI/Infra Jenkinsfile
/*
1. 변경 사항을 추적해서, 해당 서비스들만 업데이트가 되도록 한다.
2. MANUAL_MODE가 꺼져있을 때 TARGET_SERVICES가 공백이면 변경 사항이 없는 것으로 간주, CD/Infra를 호출 X
3. MANUAL_MODE가 켜져있을 때 TARGET_SERVICES가 공백이면 모든 것을 변경하는 것으로 간주
(CD/Infra에 빈 값으로 주면 모든 게 변경)

- 로깅/진단 과정에서는 변수 별로 기본값을 설정해서 파이프라인이 실패하지 않도록 설정.
*/

pipeline {
    // 어떤 노드(실행 환경)에서도 돌 수 있도록.
    agent any

    // 설정
    options {
        // 로그에 시간 추가, Jenkins를 KTC로 설정해둠.
        timestamps()
        // 같은 Job 동시 실행 방지(배포/도커 관련 충돌 예방)
        disableConcurrentBuilds()
        // Declarative 기본 Checkout을 끄고, 직접 checkout scm를 원하는 시점에 실행
        // 권한 정리해서 제거
        //skipDefaultCheckout()
    }
    // 파라미터
    parameters {
        string(name: 'TARGET_SERVICES', defaultValue: '', description: '수정/배포할 서비스')
        booleanParam(name: 'MANUAL_MODE', defaultValue: false, description: 'true = 변경 감지 스킵, TARGET_SERVICES 직접 지정')
    }
    // 환경설정
    environment {
        COMPOSE_PATH_PREFIX = "infra/compose/"
        CD_JOB_NAME = "CD/Final"

        NGINX_REL_PATH   = "infra/nginx/conf.d"
        NGINX_IMAGE      = "nginx:1.27-alpine"

        LIVEKIT_REL_PATH = "infra/livekit/config.yml"
        LIVEKIT_IMAGE    = "livekit/livekit-server:latest"

        EC2_PROJECT_PATH = "/home/ubuntu/app/infra/infra-repo"
    }

    stages {
        // 기본 정보 확인(USER, PWD, GIT_SHA)
        stage('Setup') {
            steps {
                sh '''
                USER_VAL="$(whoami 2>/dev/null || echo 'unknown-user')"
                PWD_VAL="$(pwd 2>/dev/null || echo 'unknown-pwd')"

                if command -v git >/dev/null 2>&1; then
                    # git은 있는데 레포가 아닐 수 있으니 단계별 fallback
                    GIT_SHA="$(git rev-parse --short HEAD 2>/dev/null || echo 'no-git-repo')"
                else
                    GIT_SHA="no-git"
                fi

                echo "USER=${USER_VAL}"
                echo "PWD=${PWD_VAL}"
                echo "GIT_SHA=${GIT_SHA}"
                '''
            }
        }

        // 변경 사항 감지
        stage('Detect Changes') {
            steps {
                script {
                    if (params.MANUAL_MODE) {
                        echo "⚠️ MANUAL_MODE is ON. Skipping [Detect Changes] stage"
                        echo "🎯 Target Services: ${params.TARGET_SERVICES}"

                        sh """
                        echo "--- 🛠️ Manual Selection Mode ---"
                        > changed_files.txt
                        for service in \$(echo "${params.TARGET_SERVICES}" | tr ',' ' '); do
                            echo "infra/\$service/manual_trigger" >> changed_files.txt
                        done
                        echo "📄 Created manual changed_files.txt:"
                        cat changed_files.txt
                        """
                    } else {
                        // 자동 감지 로직 (GitLab 변수 대응 + 방어적 로직)
                        sh '''#!/usr/bin/env bash
                        set -euo pipefail

                        HEAD_SHA="$(git rev-parse HEAD)"

                        # 1. Shallow Clone 체크 (인프라 배포 누락의 주범)
                        if [ "$(git rev-parse --is-shallow-repository 2>/dev/null)" = "true" ]; then
                            echo "⚠️ [WARN] Shallow repository detected. 히스토리가 부족하여 변경 감지가 누락될 수 있습니다."
                        fi

                        # 2. Base 커밋 결정 (우선순위: GitLab MR 변수 -> 이전 성공 커밋 -> Fallback 100개)
                        BASE=""

                        # GitLab 환경변수 확인 (있을 경우 1순위)
                        if [ -n "${CI_MERGE_REQUEST_DIFF_BASE_SHA:-}" ] && git cat-file -e "${CI_MERGE_REQUEST_DIFF_BASE_SHA}" 2>/dev/null; then
                            BASE="${CI_MERGE_REQUEST_DIFF_BASE_SHA}"
                            echo "🔄 [LOG] GitLab MR Diff Base 사용: $BASE"
                        # 이전 성공 빌드 커밋 확인 (2순위)
                        elif [ -n "${GIT_PREVIOUS_SUCCESSFUL_COMMIT:-}" ] && git cat-file -e "${GIT_PREVIOUS_SUCCESSFUL_COMMIT}" 2>/dev/null; then
                            BASE="${GIT_PREVIOUS_SUCCESSFUL_COMMIT}"
                            echo "🔄 [LOG] 이전 성공 빌드 커밋 사용: $BASE"
                        fi

                        # 3. RANGE 설정
                        if [ -n "$BASE" ]; then
                            if [ "$BASE" = "$HEAD_SHA" ]; then
                                echo "ℹ️ [LOG] BASE == HEAD. 새로운 커밋이 없습니다."
                                RANGE="" # 혹은 증분이 없음을 명시
                            else
                                RANGE="$BASE..HEAD"
                            fi
                        else
                            # 4. Fallback: 최대 100개까지 확인
                            echo "⚠️ [WARN] 적절한 BASE 커밋을 찾지 못했습니다. Fallback 모드(최대 100개)로 진입합니다."
                            TOTAL_COMMITS=$(git rev-list --count HEAD)
                            if [ "$TOTAL_COMMITS" -gt 100 ]; then
                                RANGE="HEAD~100..HEAD"
                                echo "📡 [LOG] 최근 100개의 커밋을 대조합니다."
                            else
                                # 루트가 여러 개일 경우 대비 tail -n 1 처리
                                ROOT_SHA="$(git rev-list --max-parents=0 HEAD | tail -n 1)"
                                RANGE="${ROOT_SHA}..HEAD"
                                echo "📂 [LOG] 전체 히스토리($TOTAL_COMMITS개)를 대조합니다."
                            fi
                        fi

                        # 5. Diff 실행
                        if [ -n "$RANGE" ]; then
                            echo "🔍 Comparing range: $RANGE"
                            git diff --name-only "$RANGE" > changed_files.txt
                        else
                            > changed_files.txt
                        fi

                        if [ ! -s changed_files.txt ]; then
                            echo "📢 No changes detected."
                        else
                            echo "📁 Detected $(wc -l < changed_files.txt) changed files."
                            head -n 20 changed_files.txt
                        fi
                        '''
                    }
                }
            }
        }

        stage('Compute Targets (env-safe)') {
            steps {
                script {
                    env.RUN_CD = 'false'
                    env.EFFECTIVE_TARGET_SERVICES = ''
                    env.COMPOSE_CHANGED = 'false'
                    def targets = []
                    def appAllowed = ['ai', 'backend', 'backend.dev', 'certbot', 'frontend', 'frontend.dev', 'livekit', 'nginx']
                    // 1) 수동 override
                    def manual = (params.TARGET_SERVICES ?: '').trim()
                    if (params.MANUAL_MODE) {
                        env.RUN_CD = 'true'
                        env.COMPOSE_CHANGED = 'true'
                        if (manual == '') {
                            // TARGET_SERVICES가 공백이면 CD에 빈 값을 전달 (CD에서 전체 변경 처리)
                            env.EFFECTIVE_TARGET_SERVICES = ''
                            echo "📢 MANUAL_MODE ON + Empty Target: Requesting FULL deployment to CD."
                        } else {
                            // 값이 있으면 해당 서비스만 전달
                            env.EFFECTIVE_TARGET_SERVICES = manual.replace(',', ' ')
                            echo "🎯 MANUAL_MODE ON: Targeting specific services: ${env.EFFECTIVE_TARGET_SERVICES}"
                        }
                        return
                    }

                    if (manual != '') {
                        env.RUN_CD = 'true'
                        env.EFFECTIVE_TARGET_SERVICES = manual.replace(',', ' ')
                        echo "Manual override -> Targets: ${env.EFFECTIVE_TARGET_SERVICES}"
                        return
                    }

                    // 2) 변경 파일 목록 읽기
                    def changedLines = []
                    try {
                        if (fileExists('changed_files.txt')) {
                            changedLines = readFile('changed_files.txt').readLines().collect { it.trim() }.findAll { it }
                        }
                    } catch (ignored) { }

                    if (changedLines.isEmpty()) {
                        echo "No changes detected."
                        return
                    }

                    // 3) Compose 파일 변경 감지 -> 서비스명 추출
                    changedLines.each { line ->
                        if (line.startsWith(env.COMPOSE_PATH_PREFIX) && (line.endsWith(".yml") || line.endsWith(".yaml"))) {
                            env.COMPOSE_CHANGED = 'true'
                            def fileName = line.split('/').last()
                            def parts = fileName.split('\\.')
                            if (parts.size() >= 3) {
                                def serviceIdentifier = parts[1..-2].join('.')
                                targets << serviceIdentifier
                            }
                        }
                    }

                    // 4) 관련 설정(conf 등) 변경 시 타겟 추가
                    if (changedLines.any { it.startsWith("infra/nginx/") }) targets << 'nginx'
                    if (changedLines.any { it.startsWith("infra/certbot/") }) {
                        targets << 'certbot'
                        targets << 'nginx' // 의존성 반영
                    }
                    if (changedLines.any { it.startsWith("infra/livekit/") || it.contains("livekit") }) {
                        targets << 'livekit'
                    }

                    // 5) 결과 정리
                    // 중복 제거 후 화이트리스트(appAllowed)에 있는 것만 추출
                    def filteredAppTargets = targets.unique().findAll { it in appAllowed }

                    // 제외된 서비스(모니터링 등)가 있다면 로그 출력
                    def ignored = targets.unique().findAll { !(it in appAllowed) }
                    if (!ignored.isEmpty()) {
                        echo "🛡️ CI/Infra Defense: Ignoring non-app services: 🚫 ${ignored}"
                    }

                    // 필터링된 결과가 있을 때만 배포 진행
                    if (!filteredAppTargets.isEmpty()) {
                        env.RUN_CD = 'true'
                        env.EFFECTIVE_TARGET_SERVICES = filteredAppTargets.join(' ')
                        echo "🚀 Final compute targets: ✅ ${env.EFFECTIVE_TARGET_SERVICES}"
                    } else {
                        echo "⚠️ No app-related changes detected after filtering."
                    }
                }
            }
        }


        stage('Nginx Lint (conf.d)') {
            when {
                expression {
                    if (env.RUN_CD != 'true') return false
                    def ts = (env.EFFECTIVE_TARGET_SERVICES ?: '').trim()
                    return ts.tokenize().contains('nginx')
                }
            }
            steps {
                echo "===== NGINX CONFIG LINT ====="
                sh '''
                set -euo pipefail

                # [수정] 위에서 정의한 변수(NGINX_REL_PATH) 사용
                ABS_CONFD="$(pwd)/${NGINX_REL_PATH}"

                if [ ! -d "$ABS_CONFD" ]; then
                    echo "ERROR: nginx conf.d dir not found: $ABS_CONFD"
                    ls -al "$(pwd)/infra/nginx" || true
                    exit 1
                fi

                if ! command -v docker >/dev/null 2>&1; then
                    echo "ERROR: docker not available."
                    exit 1
                fi

                ls -al "$ABS_CONFD"

                docker run --rm \
                    -v "$ABS_CONFD":/etc/nginx/conf.d:ro \
                    "${NGINX_IMAGE}" \
                    nginx -t
                '''
            }
        }

        stage('LiveKit Config Check') {
            when {
                expression {
                    if (env.RUN_CD != 'true') return false
                    def ts = (env.EFFECTIVE_TARGET_SERVICES ?: '').trim()
                    return ts.tokenize().contains('livekit')
                }
            }
            environment {
                // 빌드 번호를 섞어 고유한 컨테이너 이름 생성
                TEST_CONTAINER = "ci-test-livekit-${env.BUILD_NUMBER}"
            }
            steps {
                echo "===== LIVEKIT CONFIG CHECK ====="
                sh '''
                set -euo pipefail
                ABS_CONFIG="$(pwd)/${LIVEKIT_REL_PATH}"

                if [ ! -f "$ABS_CONFIG" ]; then
                    echo "ERROR: LiveKit config not found: $ABS_CONFIG"
                    exit 1
                fi

                # 컨테이너 실행
                docker run -d --name "${TEST_CONTAINER}" \
                    -v "$ABS_CONFIG":/etc/livekit/config.yml:ro \
                    "${LIVEKIT_IMAGE}" \
                    --config /etc/livekit/config.yml

                sleep 5  # 조금 더 여유 있게 대기

                # 상태 확인
                if ! docker ps --format '{{.Names}}' | grep -q "^${TEST_CONTAINER}$"; then
                    echo "LiveKit died. Logs:"
                    docker logs "${TEST_CONTAINER}"
                    exit 1
                fi
                echo "LiveKit check passed."
                '''
            }
            // 성공하든 실패하든 실행되어 컨테이너를 정리함
            post {
                always {
                    script {
                        sh "docker rm -f ${env.TEST_CONTAINER} >/dev/null 2>&1 || true"
                    }
                }
            }
        }

        stage('Sync Focused Files') {
            when { expression { return env.RUN_CD == 'true' } }
            steps {
                script {
                    // Compose 파일들 동기화
                    if (env.COMPOSE_CHANGED == 'true') {
                        echo "Syncing: ./infra/compose/ -> ${env.EC2_PROJECT_PATH}/infra/compose/"
                        sh "rsync -avz --delete ./infra/compose/ ${env.EC2_PROJECT_PATH}/infra/compose/"
                    }

                    // 서비스별 설정 파일 동기화
                    def targetList = (env.EFFECTIVE_TARGET_SERVICES ?: '').tokenize()
                    targetList.each { service ->
                        echo "Syncing config for: ${service}"
                        sh """
                        if [ -d "./infra/${service}" ]; then
                            rsync -avz --delete ./infra/${service}/ ${env.EC2_PROJECT_PATH}/infra/${service}/
                        else
                            echo "Directory ./infra/${service} not found. Skipping."
                        fi
                        """
                    }
                }
            }
        }

        stage('Trigger CD/Final') {
            when { expression { return (env.RUN_CD ?: 'false') == 'true' } }
            steps {
                script {
                    echo "===== TRIGGERING CD/Final JOB ====="

                    // 다운스트림 CD 잡을 호출 (파라미터 전달)
                    build job: 'CD/Final',
                        wait: true,
                        parameters: [
                            string(name: 'TARGET_SERVICES', value: env.EFFECTIVE_TARGET_SERVICES)
                        ]
                }
            }
        }
    }
}