<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 로그 파일 경로 설정 (Docker 컨테이너 내부 경로) -->
    <property name="LOG_PATH" value="/app/logs"/>
    <property name="LOG_FILE_NAME" value="mento"/>

    <!-- 콘솔 출력 패턴 -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{userId:-anonymous}] [%X{traceId:-NONE}] [%X{httpMethod:-}:%X{requestUri:-}] [%X{executionTime:-}] %logger{36} - %msg%n"/>


    <!-- 콘솔 Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- JSON 파일 Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.json</file>

        <!-- Rolling 정책 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.json</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>15</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>

        <!-- ECS 형식 JSON Encoder -->
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>@timestamp</fieldName>
                    <timeZone>UTC</timeZone>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</pattern>
                </timestamp>

                <logLevel>
                    <fieldName>log.level</fieldName>
                </logLevel>

                <pattern>
                    <pattern>
                        {
                          "service.name": "mento-backend",
                          "environment": "live"
                        }
                    </pattern>
                </pattern>

                <loggerName>
                    <fieldName>event.name</fieldName>
                </loggerName>
                <threadName>
                    <fieldName>process.thread.name</fieldName>
                </threadName>
                <message>
                    <fieldName>message</fieldName>
                </message>
                <throwableClassName>
                    <fieldName>error.type</fieldName>
                </throwableClassName>
                <stackTrace>
                    <fieldName>error.stack_trace</fieldName>
                </stackTrace>

                <mdc>
                    <includeMdcKeyName>traceId</includeMdcKeyName>
                    <mdcKeyFieldName>traceId:trace.id</mdcKeyFieldName>
                </mdc>

                <mdc>
                    <includeMdcKeyName>userId</includeMdcKeyName>
                    <mdcKeyFieldName>userId:user.id</mdcKeyFieldName>
                </mdc>

                <mdc>
                    <includeMdcKeyName>httpMethod</includeMdcKeyName>
                    <mdcKeyFieldName>httpMethod:http.request.method</mdcKeyFieldName>
                </mdc>

                <mdc>
                    <includeMdcKeyName>requestUri</includeMdcKeyName>
                    <mdcKeyFieldName>requestUri:url.path</mdcKeyFieldName>
                </mdc>

                <mdc>
                    <includeMdcKeyName>executionTime</includeMdcKeyName>
                    <mdcKeyFieldName>executionTime:duration_ms</mdcKeyFieldName>
                </mdc>

                <pattern>
                    <pattern>
                        {
                          "git.commit_short": "${GIT_COMMIT_SHORT:-unknown}"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <!-- 로거 레벨 설정 (Dev) -->
    <logger name="mento.backend" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.hibernate" level="INFO"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>