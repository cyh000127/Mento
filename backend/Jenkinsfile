//CI/BE Jenkinsfile

pipeline {
    agent any

    environment {
        DOCKERHUB_REPO = "ejjem/s14p11a704"
        DOCKER_CREDENTIAL_ID = "DockerHub_Token"
    }

    stages {
            stage('Checkout') {
                steps {
                    checkout scm
                }
            }

        stage('Backend Test') {
            steps {
                dir('backend') { // 디렉토리 이동
                    echo "===== STARTING TESTS ====="
                    sh 'chmod +x gradlew' // 실행 권한 부여
                    sh './gradlew test || echo "Test failed but continuing..." '
                }
            }
        }

        stage('Backend Build') {
            steps {
                dir('backend') { // 디렉토리 이동
                    echo "===== BUILDING JAR ====="
                    sh 'chmod +x gradlew'
                    sh './gradlew clean build -x test'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo "===== DOCKERIZING ====="
                    script {
                        dir('backend') { // 디렉토리 이동
                            // Docker Build
                            // 태그: backend (고정 태그 사용)
                            sh "docker build -t ${DOCKERHUB_REPO}:backend ."

                            // Docker Login & Push
                            withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIAL_ID}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                            sh "docker push ${DOCKERHUB_REPO}:backend"
                        }
                        // Clean up local images
                        sh 'docker rmi ejjem/s14p11a704:backend || true'
                    }
                }
            }
        }
        stage('Sync file to EC2'){
            steps {
                script {
                    echo "===== COPYING redis.conf, init.sql TO INFRA DIRECTORY (LOCAL) ====="
                    // EC2 내부의 절대 경로 정의
                    def TARGET_SCRIPT_DIR = "/home/ubuntu/app/infra/infra-repo/infra/script"
                    def TARGET_CONF_DIR = "/home/ubuntu/app/infra/infra-repo/infra/conf"
                   // 1. 디렉토리 생성
                    sh "mkdir -p ${TARGET_SCRIPT_DIR}"
                    sh "mkdir -p ${TARGET_CONF_DIR}"

                    // 2. 로컬 복사
                    sh "cp backend/script/init.sql ${TARGET_SCRIPT_DIR}/init.sql"
                    sh "cp backend/redis.conf ${TARGET_CONF_DIR}/redis.conf"
                    sh "cp backend/redis.conf ${TARGET_CONF_DIR}/my.conf"

                    // 3. 권한 설정
                    sh "chmod 644 ${TARGET_SCRIPT_DIR}/init.sql"
                    sh "chmod 644 ${TARGET_CONF_DIR}/redis.conf"
                    sh "chmod 644 ${TARGET_CONF_DIR}/my.conf"
                }
            }
        }


        stage('Trigger CD') {
            steps {
                script {
                    echo "===== TRIGGER CD/FINAL ====="
                    // CD 트리거는 디렉토리와 상관없이 수행
                    build job: 'CD/Final',
                        wait: true,
                        parameters: [
                        string(name: 'TARGET_SERVICES', value: 'app'),
                        ]
                }
            }
        }
    }
    post {
        success {
            echo "CI(BE) SUCCESS"
            sh 'date "+%Y-%m-%d %H:%M:%S %Z"'
        }
        failure {
            echo "CI(BE) FAILURE"
            sh 'date "+%Y-%m-%d %H:%M:%S %Z"'
        }
        always {
            echo "CI(BE) DONE"
        }
    }
}