//CI/BE Jenkinsfile

pipeline {
    agent any

    environment {
        DOCKERHUB_REPO = "ejjem/mento-backend"
        DOCKER_CREDENTIAL_ID = "DockerHub_Token"
    }

    stages {
            stage('Checkout') {
                steps {
                    checkout scm
                }
            }

            stage('Backend Test') {
                steps {
                    dir('backend') { // 디렉토리 이동
                        echo "===== STARTING TESTS ====="
                        //sh 'chmod +x gradlew' // 실행 권한 부여
                        //sh './gradlew test'
                        //sh './gradlew test || echo "Test failed but continuing..." '
                    }
                }
            }

            stage('Backend Build') {
                steps {
                    dir('backend') { // 디렉토리 이동
                        echo "===== BUILDING JAR ====="
                        //sh 'chmod +x gradlew'
                        //sh './gradlew clean build -x test'
                    }
                }
            }

            stage('Docker Build & Push') {
                steps {
                    echo "===== DOCKERIZING ====="
                    script {
                        dir('backend') { // 디렉토리 이동
                            sh "mkdir -p build/logs"
                            sh "chmod +x gradlew"
                            withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDENTIAL_ID}", usernameVariable: 'DJIB_USER', passwordVariable: 'DJIB_AUTH')]) {
                                 // Jib 실행 시에도 backend 폴더 내의 gradlew 사용
                                 sh "./gradlew jib -Djib.to.auth.username=${DJIB_USER} -Djib.to.auth.password=${DJIB_AUTH} -Djib.to.image=${DOCKERHUB_REPO}"
                            }
                        }
                    }
                }
            }

            stage('Trigger CD') {
                steps {
                    script {
                      echo "===== TRIGGER CD/FINAL ====="
                      // CD 트리거는 디렉토리와 상관없이 수행
                      build job: 'CD/Final',
                        wait: true,
                        parameters: [
                          string(name: 'TARGET_SERVICES', value: 'backend'),
                        ]
                    }
                }
            }
        }

    post {
      success {
        echo "CI(BE) SUCCESS"
        sh 'date "+%Y-%m-%d %H:%M:%S %Z"'
      }
      failure {
        echo "CI(BE) FAILURE"
        sh 'date "+%Y-%m-%d %H:%M:%S %Z"'
      }
      always {
        echo "CI(BE) DONE"
      }
    }

}